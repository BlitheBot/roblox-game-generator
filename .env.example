# ─────────────────────────────────────────────
# OpenRouter — all LLM calls route through here
# OPENROUTER_BASE_URL only needs setting for keyless
# integration tests against scripts/mock_openrouter.py
# ─────────────────────────────────────────────
OPENROUTER_API_KEY=
#OPENROUTER_BASE_URL=http://127.0.0.1:8901/api/v1

# ─────────────────────────────────────────────
# Dry run — build everything but never publish.
# Verify with: python -m scripts.dry_run
# ─────────────────────────────────────────────
DRY_RUN=false

# ─────────────────────────────────────────────
# Roblox Open Cloud — one key set per genre account
# Create accounts per Section 11, save IDs here.
# Each game needs its own place (spec 13): list up to 5
# pre-created place ids per account in ROBLOX_PLACE_IDS_*
# (comma-separated). The singular ROBLOX_PLACE_ID_* form
# still works as a pool of one. When the pool fills up the
# system alerts via Discord instead of overwriting a game.
# ─────────────────────────────────────────────
ROBLOX_API_KEY_IDLE=
ROBLOX_UNIVERSE_ID_IDLE=
ROBLOX_PLACE_IDS_IDLE=

ROBLOX_API_KEY_HORROR=
ROBLOX_UNIVERSE_ID_HORROR=
ROBLOX_PLACE_IDS_HORROR=

ROBLOX_API_KEY_SIM=
ROBLOX_UNIVERSE_ID_SIM=
ROBLOX_PLACE_IDS_SIM=

# ─────────────────────────────────────────────
# Discord — webhook for alerts and weekly digest
# ─────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ─────────────────────────────────────────────
# Discord bot — DM approval flow (spec Section 12)
# Create a bot at https://discord.com/developers, enable the
# MESSAGE CONTENT intent, and put your Discord user id below.
# Without these, previews fall back to the webhook channel.
# ─────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_OWNER_ID=

# ─────────────────────────────────────────────
# Postgres — self-hosted on VPS
# Format: postgresql://user:password@host:5432/dbname
# ─────────────────────────────────────────────
DATABASE_URL=

# ─────────────────────────────────────────────
# Reddit API — for MetaScout r/roblox scraping
# Register at https://www.reddit.com/prefs/apps
# ─────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=roblox-game-studio/1.0

# ─────────────────────────────────────────────
# RapidAPI — TikTok trending data for TrendPredictor
# Subscribe to a TikTok trending API on RapidAPI hub
# ─────────────────────────────────────────────
RAPIDAPI_KEY=
TIKTOK_REGION=US

# ─────────────────────────────────────────────
# Model overrides (spec Section 8 defaults shown).
# Change here if OpenRouter delists a model — no code
# change needed. IMAGE_MODEL must support image output
# via chat completions.
# ─────────────────────────────────────────────
#LLM_MODEL_FAST=google/gemini-flash-1.5
#LLM_MODEL_REASONING=deepseek/deepseek-chat
#LLM_MODEL_CODE=anthropic/claude-sonnet-4-6
#LLM_MODEL_CODE_ESCALATION=anthropic/claude-fable-5
#IMAGE_MODEL=google/gemini-2.5-flash-image

# ─────────────────────────────────────────────
# Optional — Robux ad spend (disabled by default)
# Set ENABLE_ADS=true and a budget to activate
# ─────────────────────────────────────────────
ENABLE_ADS=false
ADS_BUDGET_ROBUX=0

# ─────────────────────────────────────────────
# LiveOps bot (improvement 8) — weekly Monday-10:00 cycle that
# updates the top 5 games by 7-day average CCU with a content
# drop, threshold-driven balance tuning, and seasonal reskins
# (reverted automatically 3 days after the season ends).
# Disabled by default so it doesn't fire until you're ready.
# ─────────────────────────────────────────────
ENABLE_LIVEOPS=false

# ─────────────────────────────────────────────
# Marketing videos (improvement 7) — short-form promo video
# generated and published after every successful game publish.
# Disabled by default; existing deployments are unaffected
# until you flip ENABLE_MARKETING_VIDEOS=true.
# MARKETING_PLATFORMS enables platforms individually.
# ─────────────────────────────────────────────
ENABLE_MARKETING_VIDEOS=false
MARKETING_PLATFORMS=youtube,tiktok,instagram

# OpenAI TTS voiceover (tts-1, onyx). Leave empty to use the free
# gTTS fallback (no key needed).
OPENAI_API_KEY=

# YouTube Data API v3 — OAuth2 refresh-token flow (one-time setup
# steps in DEPLOY.md section 9a)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# TikTok Content Posting API v2 (DEPLOY.md section 9b).
# Pre-audit apps are forced to SELF_ONLY visibility — set
# TIKTOK_PRIVACY_LEVEL=SELF_ONLY until your app passes audit.
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=
#TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE

# Instagram Graph API — Reels on a Facebook-connected Business or
# Creator account (DEPLOY.md section 9c)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# ─────────────────────────────────────────────
# Supervised mode — pauses before each publish for Discord approval.
# Leave EMPTY: the DB state starts supervised and auto-disables after
# 5 approved games. Set true to force back on, false to force off.
# ─────────────────────────────────────────────
SUPERVISED_MODE=

# ─────────────────────────────────────────────
# Viability gate threshold (default 0.65)
# Lowered to 0.50 automatically after 3 failed cycles
# ─────────────────────────────────────────────
VIABILITY_THRESHOLD=0.65

# ─────────────────────────────────────────────
# Disk management — builds directory on VPS
# ─────────────────────────────────────────────
BUILDS_ROOT=/builds
MAX_BUILDS_PER_GENRE=10

# ─────────────────────────────────────────────
# Rojo binary path — only needed when `rojo` on
# PATH is a Rokit shim requiring a project manifest
# ─────────────────────────────────────────────
#ROJO_BINARY=/home/studio/.rokit/tool-storage/rojo-rbx/rojo/7.6.1/rojo
