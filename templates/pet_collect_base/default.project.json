{
    "name": "{{GAME_TITLE}}",
    "tree": {
        "$className": "DataModel",
        "ReplicatedStorage": {
            "Shared": { "$path": "src/shared" },
            "Remotes": {
                "$className": "Folder",
                "RequestHatch": { "$className": "RemoteEvent" },
                "RequestEquip": { "$className": "RemoteEvent" },
                "RequestTrade": { "$className": "RemoteEvent" },
                "StateChanged": { "$className": "RemoteEvent" },
                "SocialProofAnnouncement": { "$className": "RemoteEvent" },
                "ReturnMessages": { "$className": "RemoteEvent" }
            },
            "ToolboxAssets": { "$className": "Folder" }
        },
        "ServerScriptService": {
            "Server": { "$path": "src/server" },
            "World": { "$path": "src/ServerScriptService" }
        },
        "StarterPlayer": {
            "StarterPlayerScripts": {
                "Client": { "$path": "src/client" }
            }
        },
        "StarterGui": {
            "$path": "src/StarterGui"
        }
    }
