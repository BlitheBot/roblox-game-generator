                "TutorialComplete": { "$className": "RemoteEvent" },
                "PlaySound": { "$className": "RemoteEvent" },
                "Volume": { "$className": "RemoteEvent" },
                "Notification": { "$className": "RemoteEvent" },
                "StartOnboarding": { "$className": "RemoteEvent" },
                "CompleteOnboarding": { "$className": "RemoteEvent" },
                "OnboardingStepComplete": { "$className": "RemoteEvent" },
                "UpdateHUD": { "$className": "RemoteEvent" },
                "ServerError": { "$className": "RemoteEvent" },
                "LeaderboardUpdate": { "$className": "RemoteEvent" },
                "UpdateProgress": { "$className": "RemoteEvent" }
