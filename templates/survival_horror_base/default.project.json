{
    "name": "{{GAME_TITLE}}",
    "tree": {
        "$className": "DataModel",
        "ReplicatedStorage": {
            "Shared": { "$path": "src/shared" },
            "Remotes": {
                "$className": "Folder",
                "RequestVote": { "$className": "RemoteEvent" },
                "RoundState": { "$className": "RemoteEvent" },
                "SocialProofAnnouncement": { "$className": "RemoteEvent" },
                "ReturnMessages": { "$className": "RemoteEvent" },
                "TutorialComplete": { "$className": "RemoteEvent" }
            },
            "ToolboxAssets": { "$className": "Folder" },
            "ToggleShop": { "$className": "BindableEvent" }
        },
        "ServerScriptService": {
            "Server": { "$path": "src/server" },
            "World": { "$path": "src/ServerScriptService" }
        },
        "StarterPlayer": {
            "StarterPlayerScripts": {
                "Client": { "$path": "src/client" }
            }
        },
        "StarterGui": {
            "$path": "src/StarterGui"
        },
        "Workspace": {
            "Lobby": { "$className": "Folder" },
            "Arena": { "$className": "Folder" }
        },
        "Lighting": {
            "$properties": {
                "Brightness": 0.5,
                "ClockTime": 0,
                "FogEnd": 120,
                "FogColor": [0.05, 0.05, 0.08]
            }
        }
    }
}
