{
    "name": "{{GAME_TITLE}}",
    "tree": {
        "$className": "DataModel",
        "ReplicatedStorage": {
            "Shared": {
                "$path": "src/shared"
            },
            "Remotes": {
                "$className": "Folder",
                "RequestPurchase": { "$className": "RemoteEvent" },
                "RequestUpgrade": { "$className": "RemoteEvent" },
                "RequestPrestige": { "$className": "RemoteEvent" },
                "StateChanged": { "$className": "RemoteEvent" },
                "SocialProofAnnouncement": { "$className": "RemoteEvent" },
                "ReturnMessages": { "$className": "RemoteEvent" },
                "TutorialComplete": { "$className": "RemoteEvent" },
                "PlaySound": { "$className": "RemoteEvent" },
                "Volume": { "$className": "RemoteEvent" },
                "Notification": { "$className": "RemoteEvent" },
                "StartOnboarding": { "$className": "RemoteEvent" },
                "CompleteOnboarding": { "$className": "RemoteEvent" },
                "OnboardingStepComplete": { "$className": "RemoteEvent" },
                "UpdateHUD": { "$className": "RemoteEvent" },
                "ServerError": { "$className": "RemoteEvent" },
                "LeaderboardUpdate": { "$className": "RemoteEvent" },
                "UpdateProgress": { "$className": "RemoteEvent" }
            },
            "ToolboxAssets": {
                "$className": "Folder"
            },
            "ToggleShop": { "$className": "BindableEvent" }
        },
        "ServerScriptService": {
            "Server": {
                "$path": "src/server"
            },
            "World": {
                "$path": "src/ServerScriptService"
            }
        },
        "StarterPlayer": {
            "StarterPlayerScripts": {
                "Client": {
                    "$path": "src/client"
                }
            }
        },
        "StarterGui": {
            "$path": "src/StarterGui"
        },
        "Workspace": {
            "$properties": {
                "FilteringEnabled": true
            },
            "Plots": {
                "$className": "Folder"
            }
        },
        "Lighting": {
            "$properties": {
                "Brightness": 2,
                "ClockTime": 14
            }
        }
    }
}
